# Oracle Access Governance — Environment Variables
# Copy this file to .env and adjust for your environment.
# NEVER commit .env to source control.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Application ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-use-a-strong-secret-in-production

# Initial admin account (created automatically on first startup)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin123!

# ── Oracle Connection (privileged service account) ───────────────────────────
# Passwords are passed via env vars only and are never stored in the app DB.
ORACLE_HOST=oracle.example.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=ORCLPDB1
ORACLE_ADMIN_USER=C##DAG_ADMIN
ORACLE_ADMIN_PASSWORD=<set-a-strong-password>
